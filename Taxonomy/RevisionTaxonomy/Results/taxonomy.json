{
  "categories": [
    {
      "name": "Reorganize Information Hierarchy",
      "description": "Changes the high-level structure, positioning, or flow of UI content and components to better guide user attention."
    },
    {
      "name": "Refine Layout & Spacing",
      "description": "Adjusts the low-level alignment, spacing, sizing, or composition of UI elements for better visual balance and structure."
    },
    {
      "name": "Clarify Function & State",
      "description": "Makes an element's purpose, interactive potential, or current state unambiguous."
    },
    {
      "name": "Add or Surface Functionality",
      "description": "Introduces a new capability, control, or piece of information, or makes an existing one more discoverable."
    },
    {
      "name": "Simplify & Reduce Clutter",
      "description": "Decreases cognitive load by removing unnecessary elements, consolidating controls, or reducing information density."
    },
    {
      "name": "Strengthen Visual Consistency",
      "description": "Aligns the styling, terminology, or interaction patterns of components with other parts of the UI or established conventions."
    },
    {
      "name": "Improve Readability & Accessibility",
      "description": "Enhances legibility and contrast to make content easier to perceive and understand, often to meet accessibility standards."
    }
